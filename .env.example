# ============================================
# 发票OCR系统 - 环境配置模板
# ============================================
#
# 使用方法：
#   1. 复制本文件为 .env: cp .env.example .env
#   2. 根据部署环境修改下方 APP_ENV 值
#   3. 生产环境必须设置 SECRET_KEY
#
# 环境切换方式（按优先级排序）：
#   方式1: 设置 APP_ENV=production  (推荐，最明确)
#   方式2: 设置 FLASK_ENV=production (Flask惯例)
#   方式3: 不设置任何环境变量       (默认 development)
#

# ---------- 运行环境 ----------
# 可选值: development | testing | production
# 默认值: development
APP_ENV=development

# Flask 配置
FLASK_APP=run.py

# ---------- 安全配置 ----------
# 开发环境可留空（自动生成随机密钥）
# 生产环境必须设置！
# 生成方法: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ---------- 腾讯云OCR API ----------
# 推荐通过Web界面系统设置页面配置
# 如需在此处配置，填入以下两项：
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=

# ---------- 数据库配置 ----------
# 默认使用SQLite，生产环境可替换为PostgreSQL/MySQL
# SQLite(默认): sqlite:///data/invoices.db
# PostgreSQL: postgresql://user:pass@localhost/dbname
# MySQL: mysql://user:pass@localhost/dbname
DATABASE_URL=

# ---------- 上传配置 ----------
# 最大上传文件大小 (默认16MB)
MAX_CONTENT_LENGTH=16777216

# ---------- 日志配置 ----------
LOG_LEVEL=INFO
